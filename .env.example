# ─────────────────────────────────────────────────────────────────────────────
# Used-Car Sales Lead-Gen Platform — environment variables
# Copy to .env.local and fill in. Never commit real secrets (.env* is gitignored).
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (NEW project — create at supabase.com, then paste its keys here) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── App ──
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Admin bootstrap (comma-separated allowlist is a fallback; admin_roles is primary) ──
ADMIN_EMAIL=
ADMIN_EMAIL_ALLOWLIST=

# ── Anti-spam: Cloudflare Turnstile ──
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Set to "true" in non-prod to skip Turnstile verification during local dev.
TURNSTILE_SKIP=

# ── Rate limiting: Redis (Upstash-compatible). Falls back to in-memory if unset. ──
REDIS_URL=
# Salt for hashing lead IP addresses (never store raw IPs).
IP_HASH_SECRET=

# ── Transactional email: SMTP (nodemailer). No-ops if unset. ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
REPLY_TO_EMAIL=
CONTACT_EMAIL_TO=

# ── Search: Typesense (optional; search degrades gracefully if unset) ──
TYPESENSE_HOST=
TYPESENSE_PORT=443
TYPESENSE_PROTOCOL=https
TYPESENSE_API_KEY=
# Auth token the search-index-worker edge function expects.
WORKER_API_KEY=

# ── Maps (VDP / contact / location pages) ──
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ── Cron auth (lead anonymization / reminders) ──
CRON_SECRET=

# ── Analytics / SEO verification (optional) ──
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ── Social links (optional; rendered in footer) ──
NEXT_PUBLIC_SOCIAL_FACEBOOK_URL=
NEXT_PUBLIC_SOCIAL_INSTAGRAM_URL=
NEXT_PUBLIC_SOCIAL_LINKEDIN_URL=
NEXT_PUBLIC_SOCIAL_X_URL=
